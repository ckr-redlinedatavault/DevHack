// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id                   String             @id @default(cuid())
  email                String             @unique
  password             String?
  name                 String
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime           @default(now())
  members              TeamMember[]
  tasks                Task[]
  problemStatements    ProblemStatement[]
  joinRequests         JoinRequest[]
  messages             Message[]
}

model Team {
  id            String        @id @default(cuid())
  name          String
  projectName   String
  hackathonName String
  description   String?
  teamSize      Int           @default(1)
  inviteCode    String        @unique
  createdAt     DateTime      @default(now())
  members       TeamMember[]
  tasks         Task[]
  resources     Resource[]
  notes         Note[]
  submission    Submission?
  joinRequests  JoinRequest[]
  problemStatements ProblemStatement[]
  updates       TeamUpdate[]
  messages      Message[]
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  role   Role   @default(MEMBER)
  team   Team   @relation(fields: [teamId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

enum Role {
  LEAD
  MEMBER
}

model JoinRequest {
  id        String        @id @default(cuid())
  teamId    String
  userId    String
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  team      Team          @relation(fields: [teamId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}


model Task {
  id          String     @id @default(cuid())
  teamId      String
  title       String
  description String?
  assignedTo  String?
  status      TaskStatus @default(BACKLOG)
  team        Team       @relation(fields: [teamId], references: [id])
  user        User?      @relation(fields: [assignedTo], references: [id])
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
}

model Resource {
  id     String @id @default(cuid())
  teamId String
  title  String
  url    String
  team   Team   @relation(fields: [teamId], references: [id])
}

model Note {
  id      String @id @default(cuid())
  teamId  String
  title   String
  content String
  team    Team   @relation(fields: [teamId], references: [id])
}

model Submission {
  id               String  @id @default(cuid())
  teamId           String  @unique
  problemStatement String?
  solution         String?
  techStack        String?
  videoUrl         String?
  deckUrl          String?
  team             Team    @relation(fields: [teamId], references: [id])
}

model ProblemStatement {
  id          String        @id @default(cuid())
  teamId      String
  team        Team          @relation(fields: [teamId], references: [id])
  creatorId   String?
  creator     User?         @relation(fields: [creatorId], references: [id])
  title       String
  description String
  status      ProblemStatus @default(OPEN)
  createdAt   DateTime      @default(now())
}

enum ProblemStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model Organizer {
  id        String           @id @default(cuid())
  email     String           @unique
  password  String
  name      String
  createdAt DateTime         @default(now())
  events    HackathonEvent[]
}

model HackathonEvent {
  id            String              @id @default(cuid())
  organizerId   String
  organizer     Organizer           @relation(fields: [organizerId], references: [id])
  name          String
  description   String
  startDate     DateTime?
  endDate       DateTime?
  status        EventStatus         @default(UPCOMING)
  currentPhase  String              @default("Hacking")
  isRevealing   Boolean             @default(false) // For Ceremony Reveal Mode
  createdAt     DateTime            @default(now())
  registrations EventRegistration[]
  timelines     TimelineEvent[]
  judges        Judge[]
  teamUpdates   TeamUpdate[]
}

enum EventStatus {
  UPCOMING
  LIVE
  JUDGING
  ENDED
}

model Judge {
  id        String         @id @default(cuid())
  eventId   String
  event     HackathonEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  email     String
  password  String
  name      String
  scores    Score[]
}

model EventRegistration {
  id        String             @id @default(cuid())
  eventId   String
  event     HackathonEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamName  String
  leadEmail String
  status    RegistrationStatus @default(PENDING)
  totalScore Float             @default(0)
  handRaised Boolean      @default(false)
  createdAt  DateTime           @default(now())
  scores     Score[]
}

model Score {
  id             String            @id @default(cuid())
  registrationId String
  registration   EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  judgeId        String
  judge          Judge             @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  innovation     Int               @default(0)
  implementation Int               @default(0)
  design         Int               @default(0)
  impact         Int               @default(0)
  comment        String?
  createdAt      DateTime          @default(now())

  @@unique([registrationId, judgeId])
}

enum RegistrationStatus {
  PENDING
  INVITED
}

model TimelineEvent {
  id        String         @id @default(cuid())
  eventId   String
  event     HackathonEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title     String
  time      DateTime
  createdAt DateTime       @default(now())
}

model TeamUpdate {
  id        String         @id @default(cuid())
  teamId    String
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  eventId   String
  event     HackathonEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  comment   String
  research  String
  createdAt DateTime       @default(now())
}

model Message {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
